rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL SAFETY NET ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPER PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Role check: Only include if explicitly needed. User email: akwabanewsinfo@gmail.com is authorized.
    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == 'akwabanewsinfo@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- VALIDATION BLUEPRINTS ---

    function isValidArticle(data) {
      return data.keys().hasAll(['id', 'slug', 'title', 'date', 'category', 'author', 'content']) &&
             data.keys().size() >= 7 && data.keys().size() <= 20 &&
             data.id is string && data.id.size() <= 128 &&
             data.slug is string && data.slug.size() <= 256 &&
             data.title is string && data.title.size() <= 500 &&
             data.category in ['Afrique', 'Monde', 'Économie', 'Politique', 'Tech', 'Culture', 'Urgent', 'Santé', 'Science', 'Sport', 'Histoire'] &&
             data.author is string && data.author.size() <= 128 &&
             data.content is string && data.content.size() <= 50000;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'title', 'message', 'date', 'read']) &&
             data.keys().size() >= 5 && data.keys().size() <= 10 &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 1000 &&
             data.read is bool;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.displayName is string && data.displayName.size() <= 128 &&
             (!('isAdmin' in data)); // Prevent self-assignment of admin
    }

    // --- COLLECTIONS ---

    // Public Collections (ReadOnly for all, Write for Admin)
    match /articles/{articleId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidId(articleId) && isValidArticle(incoming()) && incoming().date == request.time;
      allow update: if isAdmin() && isValidArticle(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['views', 'likes', 'title', 'content', 'category', 'tags', 'image', 'video', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidId(eventId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{docId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    // Notifications (Secure Relational Access)
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || existing().userId == 'global' || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'global' || isAdmin());
      
      allow create: if isAdmin() && isValidId(notificationId) && isValidNotification(incoming()) && (
        incoming().userId == 'global' || exists(/databases/$(database)/documents/users/$(incoming().userId))
      );
      
      allow update: if (
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read'])) ||
        isAdmin()
      ) && isValidNotification(incoming());
      
      allow delete: if isAdmin();
    }

    // User Profiles (Strict PII Isolation)
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      // list: restricted to prevent scraping
      allow create: if isVerified() && isValidId(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'followedCategories', 'bookmarkedArticles', 'followedAuthors'])
      );
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Interaction Collections
    match /subscribers/{subId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isVerified();
      allow update, delete: if isAdmin() || (isVerified() && existing().userId == request.auth.uid);
    }

    match /media/{mediaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /classifieds/{classifiedId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(classifiedId);
      allow update: if (isAdmin() || (isVerified() && existing().userId == request.auth.uid)) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'category', 'location', 'imageUrl', 'status', 'updatedAt']);
      allow delete: if isAdmin() || (isVerified() && existing().userId == request.auth.uid);
    }

    match /live_blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /articles/{articleId}/chat/{msgId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(msgId);
      allow delete: if isAdmin();
    }

    match /polls/{pollId} {
      allow read: if true;
      allow update: if isVerified(); // Voting
      allow write: if isAdmin();
    }

    match /support_chats/{userId}/messages/{msgId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) || isAdmin()) && isValidId(msgId);
      allow delete: if isAdmin();
    }

    // Bootstrap Admin (Manual entry required in DB usually, but we allow bootstrapped creator)
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Fixed via console
    }
  }
}
